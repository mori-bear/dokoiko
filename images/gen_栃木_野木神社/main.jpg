    <pattern id="pattern_grid_10" patternUnits="userSpaceOnUse" width="100" height="9999">
      <rect class="grid" width="9999" height="9999" fill="url(#pattern_grid_5)" id="rect3"/>
    </pattern>
    <pattern id="pattern_grid_50" patternUnits="userSpaceOnUse" width="500" height="9999">
      <rect class="grid" width="9999" height="9999" fill="url(#pattern_grid_10)" stroke-width="3" id="rect4"/>
    </pattern>
